{
  "manifest_version": 3,
  "name": "Techdr Task Assistant",
  "version": "2.0.0",
  "description": "Login once, then assign tasks directly from extension popup.",
  "permissions": ["storage", "contextMenus", "notifications", "tabs", "scripting"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Techdr Task Assistant",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
